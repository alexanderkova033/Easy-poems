OPENAI_API_KEY=sk-...
# Optional: gpt-4o-mini (default) or gpt-4o
OPENAI_MODEL=gpt-4o-mini
PORT=8787
# Optional: frontend origin for CORS in dev, e.g. http://localhost:5173
# CORS_ORIGIN=

# OpenAI client timeout (ms); default 90000
# OPENAI_TIMEOUT_MS=90000

# Node HTTP server request timeout (ms); default 120000
# SERVER_REQUEST_TIMEOUT_MS=120000

# Max poem lines per request; default 500 (hard cap 10000)
# MAX_POEM_LINES=500

# Optional abuse guard: max analyze requests per IP per window (omit = disabled)
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW_MS=60000
