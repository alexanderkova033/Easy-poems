{
  "name": "easy-poems-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:cmu-stress": "node scripts/generate-cmu-stress.mjs",
    "check:cmu-stress": "node scripts/check-cmu-stress-fresh.mjs",
    "sync:wordlist": "node scripts/sync-wordlist.mjs",
    "postinstall": "npm run sync:wordlist",
    "build": "npm run check:cmu-stress && tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.1",
    "@codemirror/view": "^6.36.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@uiw/codemirror-extensions-basic-setup": "^4.23.10",
    "@uiw/react-codemirror": "^4.23.10",
    "docx": "^9.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "word-list": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cmu-pronouncing-dictionary": "^3.0.0",
    "jsdom": "^26.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.0.5"
  }
}
